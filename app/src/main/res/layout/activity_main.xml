<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:a="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  a:layout_width="match_parent"
  a:layout_height="match_parent"
  a:orientation="vertical"
  tools:ignore="HardcodedText">

  <LinearLayout
    a:layout_width="match_parent"
    a:layout_height="wrap_content"
    a:orientation="vertical"
    a:padding="10dp">

    <TextView
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:text="Pocket Tandas"
      a:textSize="40sp" />

    <TextView
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:layout_marginTop="10dp"
      a:text="Preferred audio output:"/>

    <RadioGroup
      a:id="@+id/output_group"
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:orientation="vertical">

      <RadioButton
        a:id="@+id/output_default"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:text="Default"/>

      <RadioButton
        a:id="@+id/output_bluetooth"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:text="Bluetooth"/>

      <RadioButton
        a:id="@+id/output_wired"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:text="3.5mm cable"/>

      <RadioButton
        a:id="@+id/output_usb"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:text="USB audio"/>
    </RadioGroup>

    <TableLayout
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:stretchColumns="0,1">

      <TableRow>
        <TextView
          a:layout_width="0dp"
          a:layout_height="wrap_content"
          a:layout_weight="1"
          a:text=""/>
        <TextView
          a:layout_width="0dp"
          a:layout_height="wrap_content"
          a:layout_weight="1"
          a:gravity="center"
          a:text="Track names via Bluetooth"/>
      </TableRow>

      <TableRow>
        <Button
          a:id="@+id/browse_mode_opener"
          a:layout_width="0dp"
          a:layout_height="wrap_content"
          a:layout_weight="1"
          a:layout_margin="10dp"
          a:text="Browse"/>
        <Button
          a:id="@+id/remote_send_opener"
          a:layout_width="0dp"
          a:layout_height="wrap_content"
          a:layout_weight="1"
          a:layout_margin="10dp"
          a:text="+ Send"/>
      </TableRow>

      <TableRow>
        <Button
          a:id="@+id/browser_queue_opener"
          a:layout_width="0dp"
          a:layout_height="wrap_content"
          a:layout_weight="1"
          a:layout_margin="10dp"
          a:text="DJ"/>
        <Button
          a:id="@+id/remote_receive_opener"
          a:layout_width="0dp"
          a:layout_height="wrap_content"
          a:layout_weight="1"
          a:layout_margin="10dp"
          a:text="+ Receive"/>
      </TableRow>

    </TableLayout>

     <Button
       a:id="@+id/stop_after_current"
       a:layout_width="match_parent"
       a:layout_height="wrap_content"
       a:layout_margin="10dp"
       a:text="Stop after current track"/>

     <Button
       a:id="@+id/clear_queue"
       a:layout_width="match_parent"
       a:layout_height="wrap_content"
       a:layout_margin="10dp"
       a:text="Clear queue"/>

    <TextView
      a:id="@+id/fade_out_label"
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:layout_marginTop="10dp"
      a:text="Fade out duration: 5 s"/>

    <SeekBar
      a:id="@+id/fade_out_slider"
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:max="9"
      a:progressTint="@color/foreground"
      a:thumbTint="@color/foreground"
      a:progressBackgroundTint="@color/buttonBackground"/>

     <Button
       a:id="@+id/show_license"
       a:layout_width="match_parent"
       a:layout_height="wrap_content"
       a:layout_margin="10dp"
       style="?android:attr/borderlessButtonStyle"
       a:text="License (GPLv3)"/>

  </LinearLayout>
</ScrollView>
