<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:a="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  a:layout_width="match_parent"
  a:layout_height="match_parent"
  a:orientation="vertical"
  tools:ignore="HardcodedText">

  <!-- Top half: File Browser -->
  <LinearLayout
    a:layout_width="match_parent"
    a:layout_height="0dp"
    a:layout_weight="1"
    a:orientation="vertical">


    <LinearLayout
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:orientation="horizontal">

      <Button
        a:id="@+id/btn_open_storage"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_margin="4dp"
        a:text="@string/browse_storage_button"
        a:textSize="14sp" />

      <Button
        a:id="@+id/btn_sort_files"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_margin="4dp"
        a:text="@string/sort_button"
        a:textSize="14sp" />

      <EditText
        a:id="@+id/file_filter_input"
        a:layout_width="0dp"
        a:layout_height="wrap_content"
        a:layout_margin="4dp"
        a:layout_weight="1"
        a:background="@color/inputBackground"
        a:hint="Filter files by name"
        a:importantForAutofill="no"
        a:maxLines="1"
        a:textColor="@color/foreground"
        a:textColorHint="@color/inputHint"
        a:textSize="14sp" />
    </LinearLayout>

    <ListView
      a:id="@+id/file_browser_list"
      a:layout_width="match_parent"
      a:layout_height="0dp"
      a:layout_weight="1"
      a:divider="@color/buttonBackground"
      a:dividerHeight="1dp" />
  </LinearLayout>

  <!-- Divider -->
  <View
    a:layout_width="match_parent"
    a:layout_height="3dp"
    a:background="@color/foreground" />

  <!-- Bottom half: Play Queue (also the drag drop target) -->
  <LinearLayout
    a:id="@+id/queue_container"
    a:layout_width="match_parent"
    a:layout_height="0dp"
    a:layout_weight="1"
    a:orientation="vertical">

    <LinearLayout
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:background="@color/buttonBackground"
      a:orientation="horizontal">

      <TextView
        a:layout_width="0dp"
        a:layout_height="wrap_content"
        a:layout_gravity="center_vertical"
        a:layout_weight="1"
        a:padding="6dp"
        a:text="Play Queue"
        a:textSize="18sp" />

      <Button
        a:id="@+id/btn_play_queue"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_margin="4dp"
        a:text="▶ Play"
        a:textSize="14sp" />

      <Button
        a:id="@+id/btn_save_queue"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_margin="4dp"
        a:text="@string/save_queue_button"
        a:textSize="14sp" />

      <Button
        a:id="@+id/btn_stop_queue"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_margin="4dp"
        a:text="@string/stop_button_text"
        a:textSize="14sp" />
    </LinearLayout>

    <TextView
      a:id="@+id/queue_empty_hint"
      a:layout_width="match_parent"
      a:layout_height="wrap_content"
      a:gravity="center"
      a:padding="16dp"
      a:text="Drag audio files here, or tap them to add"
      a:textSize="14sp"
      a:visibility="visible" />

    <ListView
      a:id="@+id/queue_list"
      a:layout_width="match_parent"
      a:layout_height="0dp"
      a:layout_weight="1"
      a:divider="@color/buttonBackground"
      a:dividerHeight="1dp"
      a:listSelector="@android:color/transparent" />
  </LinearLayout>

</LinearLayout>

